# ─── Bloombark Terminal — Backend Config ──────────────────────────────────────
# This is the tracked default config (safe to commit — no real secrets live
# here; JWT_SECRET/ENC_KEY stay auto-generated). Copy to a local untracked
# override if you need machine-specific values, or edit in place for shared
# defaults across the team.
#
# NOTE: dotenv ignores commented (#) lines entirely — a commented var falls
# back to its hardcoded default in code, it does NOT read the commented value.
# Every line below is intentionally uncommented so it's actually in effect,
# except JWT_SECRET / ENC_KEY which must stay auto-generated for security.

# ── Server ──
PORT=3001
INTERNAL_API_BASE=http://127.0.0.1:3001

# ── Network mode: testnet | mainnet ──
NETWORK_ENV=testnet

# ── Secrets ──
# Left commented on purpose: auto-generated into .secrets.json on first boot.
# Uncomment + set explicitly only for production (so sessions survive redeploys).
# JWT_SECRET=
# ENC_KEY=
# Absolute paths — leave commented to use the default (relative to backend/).
# Only set these if you need the DB/secrets file to live somewhere else.
# SECRETS_FILE_PATH=/absolute/path/to/.secrets.json
# DB_FILE_PATH=/absolute/path/to/bloombark.db

# ── CORS: comma-separated allowlist, or * to allow any origin (dev) ──
CORS_ORIGIN=*

# ── Community: Holders channel token-gate ──
# HOLDERS_GATE_TOKEN blank → native coin (ETH) gate; set a token CA → ERC-20 gate.
HOLDERS_GATE_CHAIN=ethereum
HOLDERS_GATE_TOKEN=
HOLDERS_GATE_MIN=0.1
HOLDERS_GATE_SYMBOL=

# ── Trading / external API keys (blank = unauthenticated public tier) ──
ZEROx_API_KEY=
GOPLUS_API_KEY=
GECKO_API_KEY=

# ── External API base URLs ──
DEXSCREENER_API=https://api.dexscreener.com
DEXSCREENER_CHART_API=https://io.dexscreener.com
GECKO_API=https://api.geckoterminal.com/api/v2
GOPLUS_API=https://api.gopluslabs.io/api/v1

# ── Cache tuning ──
NARRATIVE_TTL_MIN=60
DASHBOARD_TTL_SEC=120
GOPLUS_CACHE_TTL_MIN=10
GATE_CACHE_TTL_SEC=30
WALLET_MAP_CACHE_TTL_MIN=5
HOLDINGS_CACHE_TTL_SEC=60

# ── Narrative warm-up / rate-limit pacing ──
NARRATIVE_WARM_DELAY_SEC=5
NARRATIVE_FETCH_DELAY_MS=5000
NARRATIVE_RETRY_DELAY_MIN=10
NARRATIVE_WAIT_TIMEOUT_SEC=15
DASH_WARM_DELAY_SEC=1

# ── Community chat ──
CHAT_HISTORY_LIMIT=100
CHAT_DB_PRUNE_LIMIT=500
CHAT_MSG_MAX_LEN=500
CHAT_NAME_MAX_LEN=24
CHAT_BOT_COOLDOWN_SEC=120

# ── Simulated live price ticker (Market Overview / token header) ──
PRICE_TICK_INTERVAL_MS=2000
PRICE_RESEED_INTERVAL_SEC=60
PRICE_MEANREVERT_FACTOR=0.08
PRICE_NOISE_PCT=0.002
PRICE_CLAMP_PCT=0.02

# ── Auth / sessions ──
JWT_EXPIRES_IN_DAYS=7

# ── Wallet holdings / tracker filters ──
HOLDINGS_DUST_USD=0.01
HOLDINGS_MAX_RESULTS=50
WALLET_MAX_TOKENS=90
MIN_VOLUME_USD_FILTER=50
