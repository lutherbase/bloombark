# ─── Bloombark Terminal — Backend Config (template) ───────────────────────────
# `backend/.env` is tracked in git with safe team-wide defaults (no real
# secrets). Use this file only as a reference, or copy it to
# `backend/.env.local` (gitignored) to override values for your machine —
# .env.local is loaded after .env and takes priority.
#   cp .env.example .env.local
# Every value below has a safe default in code; uncomment only what you override.

# ── Server ──
PORT=3001
# Base URL for same-process self-calls (chat bot -> our own /api/predict).
# Only needed if you run behind a proxy where 127.0.0.1:$PORT isn't reachable.
#INTERNAL_API_BASE=http://127.0.0.1:3001

# ── Network mode ──
# testnet | mainnet. Unset = auto-detect (testnet on localhost, mainnet on deploy).
#NETWORK_ENV=testnet

# ── Secrets & file paths ──
# JWT/ENC secrets auto-generate into .secrets.json when unset. Set explicitly in
# production so sessions survive redeploys and multiple instances share the same keys.
#JWT_SECRET=
#ENC_KEY=
#SECRETS_FILE_PATH=/absolute/path/to/.secrets.json
#DB_FILE_PATH=/absolute/path/to/bloombark.db

# ── CORS ──
# Comma-separated allowlist of origins. Unset or "*" reflects any origin (dev).
#CORS_ORIGIN=https://app.bloombark.xyz,https://bloombark.xyz

# ── Community: Holders channel token-gate ──
# The Holders channel unlocks when a wallet holds >= HOLDERS_GATE_MIN of the token.
#   HOLDERS_GATE_TOKEN blank  → native coin (ETH) balance gate
#   HOLDERS_GATE_TOKEN = 0x.. → ERC-20 balanceOf gate for that contract
# Chain follows the active NETWORK_ENV (e.g. ethereum -> Sepolia in testnet mode).
HOLDERS_GATE_CHAIN=ethereum
HOLDERS_GATE_TOKEN=
HOLDERS_GATE_MIN=0.01
HOLDERS_GATE_SYMBOL=

# ── Trading ──
# Optional 0x aggregator API key (KyberSwap path needs none).
#ZEROx_API_KEY=
#GOPLUS_API_KEY=
#GECKO_API_KEY=

# ── External API base URLs (override to point at proxies/mirrors) ──
#DEXSCREENER_API=https://api.dexscreener.com
#DEXSCREENER_CHART_API=https://io.dexscreener.com
#GECKO_API=https://api.geckoterminal.com/api/v2
#GOPLUS_API=https://api.gopluslabs.io/api/v1

# ── Cache tuning ──
#NARRATIVE_TTL_MIN=60          # narrative categories cache lifetime
#DASHBOARD_TTL_SEC=120         # market overview cache lifetime
#GOPLUS_CACHE_TTL_MIN=10       # security scan cache lifetime
#GATE_CACHE_TTL_SEC=30         # community channel gate-check cache
#WALLET_MAP_CACHE_TTL_MIN=5    # wallet relationship map cache
#HOLDINGS_CACHE_TTL_SEC=60     # trade page holdings cache

# ── Narrative warm-up / rate-limit pacing ──
#NARRATIVE_WARM_DELAY_SEC=5     # delay before first background warm on boot
#NARRATIVE_FETCH_DELAY_MS=5000  # spacing between CoinGecko category requests
#NARRATIVE_RETRY_DELAY_MIN=10   # retry delay for categories that came back empty
#NARRATIVE_WAIT_TIMEOUT_SEC=15  # max time /api/narrative waits for a warm cache
#DASH_WARM_DELAY_SEC=1          # delay before first dashboard warm on boot

# ── Community chat ──
#CHAT_HISTORY_LIMIT=100     # messages sent to a client on room join
#CHAT_DB_PRUNE_LIMIT=500    # messages kept per room in the database
#CHAT_MSG_MAX_LEN=500       # max characters per chat message
#CHAT_NAME_MAX_LEN=24       # max characters for a display name
#CHAT_BOT_COOLDOWN_SEC=120  # min seconds between BloomBot re-analyzing the same CA

# ── Simulated live price ticker (Market Overview / token header) ──
#PRICE_TICK_INTERVAL_MS=2000     # how often a tick is pushed to subscribed clients
#PRICE_RESEED_INTERVAL_SEC=60    # how often the real price is re-fetched from DexScreener
#PRICE_MEANREVERT_FACTOR=0.08    # how strongly price pulls back toward the real seed each tick
#PRICE_NOISE_PCT=0.002           # random noise band per tick (fraction of seed price)
#PRICE_CLAMP_PCT=0.02            # max allowed drift from seed price (fraction)

# ── Auth / sessions ──
#JWT_EXPIRES_IN_DAYS=7

# ── Wallet holdings / tracker filters ──
#HOLDINGS_DUST_USD=0.01        # hide token balances worth less than this
#HOLDINGS_MAX_RESULTS=50       # max tokens returned by the holdings endpoint
#WALLET_MAX_TOKENS=90          # max ERC-20 tokens processed per wallet-tracker call
#MIN_VOLUME_USD_FILTER=50      # min 24h pool volume to trust a DexScreener price as real
